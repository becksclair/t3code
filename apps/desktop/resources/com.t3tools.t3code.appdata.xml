<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.t3tools.t3code</id>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  <name>T3 Code</name>
  <summary>Minimal web GUI for coding agents</summary>
  <description>
    <p>
      T3 Code is a minimal web-based GUI for AI coding agents like OpenAI Codex
      and Claude Code. It provides a clean interface for managing coding sessions,
      viewing conversation history, and interacting with AI-powered development tools.
    </p>
    <p>Features:</p>
    <ul>
      <li>Web-based interface for AI coding agents</li>
      <li>Session management and conversation history</li>
      <li>Support for multiple AI providers (Codex, Claude)</li>
      <li>Built-in WebSocket server for real-time communication</li>
      <li>Native desktop integration with Electron</li>
    </ul>
  </description>
  <launchable type="desktop-id">t3code.desktop</launchable>
